# documentation: https://rspamd.com/doc/modules/dkim_signing.html

enabled = true;

sign_authenticated = true;
sign_local = true;

use_domain = "header";
use_redis = false;
use_esld = true;
check_pubkey = true;

selector = "mail";
path = "/etc/rspamd/dkim/mail.private";

domain {
    {{ matrix_base_domain }} {
        path = "/etc/rspamd/dkim/mail.private";
        selector = "mail";
    }
}
